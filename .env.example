# Telegram Bot API token (from @BotFather)
BOT_TOKEN=

# Private chat ID with the bot (use @userinfobot to find)
CHAT_ID=

# Port for HTTP notifications server
NOTIFY_SERVER_PORT=8787

# Token for HTTP notifications endpoint authorization
NOTIFY_TOKEN=

# Absolute path to store quick notes as markdown files
NOTES_ROOT=/home/user/homelab-notes

# Debounce window for quick notes (seconds). Messages within this window are merged into one file.
# Default: 45
DEBOUNCE_SECS=45
